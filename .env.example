# ================================================
# MODERN E-COMMERCE MVP - Environment Variables
# ================================================
# Copy this file to .env and fill in your actual values.
# NEVER commit the .env file to version control.

# ==================== DATABASE ====================
DATABASE_URL="postgresql://user:password@localhost:5432/ecommerce?schema=public"

# ==================== NEXTAUTH ====================
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="generate-with-openssl-rand-base64-32"

# ==================== GOOGLE OAUTH ====================
GOOGLE_CLIENT_ID="your-google-client-id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# ==================== STRIPE (Card Payments) ====================
STRIPE_SECRET_KEY="sk_test_your-stripe-secret-key"
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_your-stripe-publishable-key"
STRIPE_WEBHOOK_SECRET="whsec_your-webhook-signing-secret"

# ==================== M-PESA / DARAJA API ====================
# Register at https://developer.safaricom.co.ke
MPESA_CONSUMER_KEY="your-daraja-consumer-key"
MPESA_CONSUMER_SECRET="your-daraja-consumer-secret"
MPESA_PASSKEY="your-mpesa-online-passkey"
MPESA_SHORTCODE="174379"
MPESA_CALLBACK_URL="https://your-domain.com/api/checkout/mpesa-callback"
# Use sandbox URL during development:
# https://sandbox.safaricom.co.ke

# ==================== WEB3 / CRYPTO PAYMENTS ====================
NEXT_PUBLIC_PAYMENT_WALLET_ADDRESS="0xYourEthereumWalletAddress"
NEXT_PUBLIC_USDT_CONTRACT_ADDRESS="0xdAC17F958D2ee523a2206206994597C13D831ec7"

# ==================== WHATSAPP FALLBACK ====================
NEXT_PUBLIC_WHATSAPP_NUMBER="254706270921"
